AB_ENV=local
# Service identity reported by /health and /api/v1/diagnostics.
AB_APP_NAME=AB Test Research Designer API
AB_APP_VERSION=1.1.0
# Exact commit of the running build. CI/images stamp this; when unset, a local
# run asks git and otherwise reports "unknown".
# AB_BUILD_SHA=
AB_HOST=127.0.0.1
AB_PORT=8008
# AB_DB_PATH defaults to <repo>/app/backend/data/projects.sqlite3 (absolute, computed from package location).
# Override only with an absolute path; sqlite:/// URI semantics break with bare relative paths.
# AB_DB_PATH=
# Optional. Leave empty to use the SQLite path above.
AB_DATABASE_URL=
AB_DB_POOL_SIZE=10
AB_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
AB_CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
AB_CORS_HEADERS=Accept,Content-Type
# AB_FRONTEND_DIST_PATH defaults to <repo>/app/frontend/dist. Override with an absolute path.
# AB_FRONTEND_DIST_PATH=
AB_SERVE_FRONTEND_DIST=true
AB_LLM_BASE_URL=http://localhost:8001
AB_LLM_TIMEOUT_SECONDS=60
AB_LLM_MAX_ATTEMPTS=3
AB_LLM_INITIAL_BACKOFF_SECONDS=0.1
AB_LLM_BACKOFF_MULTIPLIER=2
# Optional hosted-LLM adapter (Mistral). Leave the key empty to keep it disabled.
AB_MISTRAL_API_KEY=
AB_MISTRAL_MODEL=mistral-small-latest
AB_SQLITE_BUSY_TIMEOUT_MS=5000
AB_SQLITE_JOURNAL_MODE=WAL
AB_SQLITE_SYNCHRONOUS=NORMAL
AB_LOG_LEVEL=INFO
AB_LOG_FORMAT=plain
AB_HF_SNAPSHOT_REPO=
AB_HF_TOKEN=
AB_HF_SNAPSHOT_INTERVAL_SECONDS=900
# Seed the demo workspace on startup (idempotent; used by the hosted demo).
AB_SEED_DEMO_ON_STARTUP=false
AB_API_TOKEN=
AB_READONLY_API_TOKEN=
# Hosted-demo mode: anonymous visitors get read-only scope (calculators allowed, mutations rejected)
AB_PUBLIC_DEMO=false
AB_ADMIN_TOKEN=
# Escape hatch for the production auth gate. With AB_ENV=production the app refuses to
# start unless it can gate writes: AB_API_TOKEN, or AB_ADMIN_TOKEN (which issues the first
# write-scoped API key), or an active write-scoped API key already in the database.
# Setting this to true starts anyway, leaves every mutating endpoint open to anonymous
# callers, and logs a WARNING on every boot. Never enable it on a reachable deployment.
AB_ALLOW_INSECURE_PRODUCTION=false
AB_WORKSPACE_SIGNING_KEY=
AB_SLACK_CLIENT_ID=
AB_SLACK_CLIENT_SECRET=
AB_SLACK_SIGNING_SECRET=
AB_SLACK_REVIEW_CHANNEL=
AB_RATE_LIMIT_ENABLED=true
AB_RATE_LIMIT_REQUESTS=240
AB_RATE_LIMIT_WINDOW_SECONDS=60
AB_AUTH_FAILURE_LIMIT=20
AB_AUTH_FAILURE_WINDOW_SECONDS=60
AB_MAX_REQUEST_BODY_BYTES=1048576
AB_MAX_WORKSPACE_BODY_BYTES=8388608
# Number of trusted reverse proxies in front of the app. 0 (the default) ignores
# X-Forwarded-For entirely, so rate limits key off the direct peer. Set it to the
# real hop count only when the app is unreachable except through those proxies.
# Never set it higher than that count: a caller can prepend entries to the header,
# so an over-declared count hands it back control of its rate-limit bucket.
AB_TRUSTED_PROXY_HOPS=0
# Optional tightening: only honour X-Forwarded-For when the direct peer is one of
# these addresses / CIDR blocks. Requires AB_TRUSTED_PROXY_HOPS >= 1.
AB_TRUSTED_PROXIES=

# Retention windows in days (0 = automatic purge disabled for that table).
# Purge manually via POST /api/v1/admin/retention/purge (supports dry_run).
AB_RETENTION_EXPOSURES_DAYS=0
AB_RETENTION_CONVERSIONS_DAYS=0
AB_RETENTION_AUDIT_DAYS=0
AB_RETENTION_WEBHOOK_DELIVERIES_DAYS=0

VITE_API_BASE_URL=http://127.0.0.1:8008
